<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══ IDENTITY ═══════════════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Hayfin Capital Management</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="Inbox Filer"/>
  <Description DefaultValue="AI-powered inbox filing for Hayfin. Suggests folders, moves emails with one click."/>
  <IconUrl DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://github.com/mattsuprahayfin/hayfin-filer"/>

  <!-- ═══ PERMISSIONS ════════════════════════════════════════════════════════ -->
  <!-- ReadWriteMailbox required for moving emails via EWS -->
  <Permissions>ReadWriteMailbox</Permissions>

  <!-- ═══ HOST REQUIREMENTS ══════════════════════════════════════════════════ -->
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="MailBox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <!-- ═══ FORM SETTINGS (classic Outlook fallback) ══════════════════════════ -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ═══ RULES ══════════════════════════════════════════════════════════════ -->
  <!-- Show the add-in for all emails -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <!-- ═══ VERSION OVERRIDES (modern Outlook / OWA) ══════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
                      xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- ── DESKTOP OUTLOOK ── -->
          <DesktopFormFactor>

            <!-- Ribbon button on the Home tab -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="openTaskpaneBtn">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId1</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- ── RESOURCES ── -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/assets/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/assets/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Taskpane.Url" DefaultValue="https://mattsuprahayfin.github.io/hayfin-filer/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Inbox Filer"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="File Inbox"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Hayfin Inbox Filer to get AI filing suggestions and move emails with one click."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
